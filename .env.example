# 邮箱模式配置模板（仅邮箱模式需要；文件夹/图片模式可跳过）
# 推荐运行 npm run setup；或手动复制本文件为 .env 后填入真实值。
# 注意：.env 已被 .gitignore 忽略，不会进入版本库。

# 邮箱地址（QQ 邮箱示例）
IMAP_USER=your@qq.com

# 邮箱授权码 / 应用专用密码（不是网页登录密码）
IMAP_PASSWORD=your_email_app_password

# IMAP 服务器（QQ 邮箱默认如下）
IMAP_HOST=imap.qq.com
IMAP_PORT=993
IMAP_TLS=true
# 默认校验服务器证书；不要在生产邮箱中关闭。
IMAP_REJECT_UNAUTHORIZED=true

# 邮箱网页用户标识：QQ 邮箱通常填 QQ 号，用于生成邮件跳转超链接
MAIL_WEB_USER=your_qq_number

# 读取的邮箱文件夹，默认 INBOX
MAILBOX=INBOX

# ---- 可选：文件夹模式 / 报销包导出（不填则用默认值）----
# 文件夹模式：npm run agent -- --folder "/path/to/invoices"
# 报销包导出根目录：各平台默认 ~/报销
# REIMBURSE_ROOT=E:/报销
# 批次日期标签（默认今天）
# BATCH_DATE=2026-07-12
# 期间说明（默认「报销批次」）
# PERIOD_LABEL=报销批次
# 图片字段置信度阈值，默认 0.85
# VISION_CONFIDENCE_THRESHOLD=0.85

# 模板报销单开关：设了才接入跑批（并列于 step6，不替换）。格式 user/name[:version]
# 前提：需先用 generate-template.js 生成模板并存入模板库（templates/<user>/<name>/<version>/）
# 例：用「我」用户的 std 模板；更换版本如 我/std:2；或更换模板如 我/差旅模板
# REIMBURSEMENT_TEMPLATE=我/std
