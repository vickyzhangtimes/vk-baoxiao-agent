{
    "name":  "reimbursement-invoice-agent",
    "version":  "2.0.0",
    "private":  true,
    "description":  "本地优先的报销发票 Agent：统一处理邮箱、PDF 文件夹和图片输入，生成台账、报销单、归档与报销包。",
    "main":  "agent-controller.js",
    "scripts":  {
                    "init":  "node scripts/init-local.js",
                    "setup":  "node scripts/configure-mailbox.js",
                    "doctor":  "node scripts/doctor.js",
                    "health":  "node scripts/health-check.js",
                    "check":  "node scripts/check-syntax.js",
                    "config:check":  "node scripts/check-config.js",
                    "classify":  "node step2-classify-invoices.js",
                    "download":  "node step2-download-pdf.js",
                    "extract":  "node step3-extract-pdf.js",
                    "merge":  "node step4-merge-data.js",
                    "enrich":  "node step4b-enrich-classify.js",
                    "ledger":  "node step5-generate-ledger.js",
                    "reimb":  "node step6-generate-reimbursement.js",
                    "archive":  "node archive-invoices.js",
                    "run":  "node agent-controller.js",
                    "test":  "node --test test/*.test.js",
                    "render":  "node render-reimbursement.js",
                    "agent":  "node agent-controller.js",
                    "feedback":  "node apply-feedback.js"
                },
    "keywords":  [
                     "invoice",
                     "email",
                     "imap",
                     "codex-skill",
                     "agentic-workflow",
                     "发票"
                 ],
    "author":  "Vicky（基于 aigc猎手竹相左边 的 MIT 上游版本）",
    "license":  "MIT",
    "engines":  {
                    "node":  "\u003e=18"
                },
    "dependencies":  {
                         "exceljs":  "^4.4.0",
                         "iconv-lite":  "^0.6.3",
                         "imap":  "^0.8.19",
                         "mailparser":  "^3.9.9",
                         "node-fetch":  "^2.7.0",
                         "pdf-parse":  "^2.4.5",
                         "pdf2json":  "^4.0.3"
                     },
    "repository":  {
                       "type":  "git",
                       "url":  "git+https://github.com/vickyzhangtimes/reimbursement-invoice-agent.git"
                   },
    "homepage":  "https://github.com/vickyzhangtimes/reimbursement-invoice-agent#readme",
    "bugs":  {
                 "url":  "https://github.com/vickyzhangtimes/reimbursement-invoice-agent/issues"
             }
}
